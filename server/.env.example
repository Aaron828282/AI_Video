PORT=8787
PUBLIC_API_BASE_URL=http://localhost:8787

# Required for AI analysis
CLAUDE_AUTH_TOKEN=
CLAUDE_BASE_URL=https://code.newcli.com/claude/droid
CLAUDE_MODEL=claude-opus-4-5
# First-pass analysis can be switched to VectorEngine Gemini 2.5 Flash Lite Thinking.
# First-pass (/analyze) uses VectorEngine Gemini key below.
# VECTORENGINE_BASE_URL defaults to https://api.vectorengine.ai
VECTORENGINE_API_KEY=
VECTORENGINE_BASE_URL=https://api.vectorengine.ai
FIRST_PASS_ANALYSIS_MODEL=gemini-2.5-flash-lite-thinking
SECOND_STAGE_PROMPT_MODEL=gemini-2.5-flash-lite-thinking
# Optional: if gateway requires a fixed API key (e.g. fox), set one of:
# CLAUDE_PRIMARY_API_KEY=
# ANTHROPIC_PRIMARY_API_KEY=
# Compatibility aliases (same meaning as CLAUDE_*):
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=
ANALYSIS_CONCURRENCY=4
COZE_REQUEST_TIMEOUT_MS=420000

# Password reset email (Gmail SMTP, SSL)
RESET_EMAIL_SMTP_HOST=smtp.gmail.com
RESET_EMAIL_SMTP_PORT=587
RESET_EMAIL_SMTP_SECURE=false
RESET_EMAIL_SMTP_USER=haowenjiang75@gmail.com
RESET_EMAIL_SMTP_PASS=
RESET_EMAIL_FROM=haowenjiang75@gmail.com
# Optional SMTP tuning:
# RESET_EMAIL_SMTP_CONNECT_TIMEOUT_MS=25000
# RESET_EMAIL_SMTP_RESPONSE_TIMEOUT_MS=30000
# RESET_EMAIL_SMTP_AUTO_FALLBACK=true
# RESET_EMAIL_SMTP_FAMILY=4

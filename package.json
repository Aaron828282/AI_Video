{
  "name": "ai-auto-1688-mvp",
  "private": true,
  "version": "0.1.0",
  "main": "desktop/main.js",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build:web": "npm --workspace web run build",
    "start:server": "npm --workspace server run start",
    "start:desktop": "electron .",
    "build:exe": "npm run build:web && electron-builder --win portable"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.aiauto.m1688",
    "productName": "AI Auto 1688",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "server/src/**/*",
      "server/templates/**/*",
      "web/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "AI_Auto_1688_${version}.exe"
    }
  }
}

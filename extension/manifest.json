{
  "manifest_version": 3,
  "name": "商品抓取助手",
  "version": "0.1.3",
  "description": "拖拽 1688/淘宝/天猫/拼多多 商品图片到侧边栏，自动抓取并上传商品信息",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.1688.com/*",
    "*://*.taobao.com/*",
    "*://*.tmall.com/*",
    "*://*.yangkeduo.com/*",
    "*://*.pinduoduo.com/*",
    "http://localhost:8790/*",
    "https://*.up.railway.app/*",
    "https://ai-auto-1688-server-production.up.railway.app/*",
    "http://*/api/*",
    "https://*/api/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "商品抓取助手"
  }
}

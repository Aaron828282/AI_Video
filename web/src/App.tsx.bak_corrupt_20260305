          patchClipVideoState(recordId, setKey, clipIndex, {
            firstFrameDataUrl: dataUrl,
            firstFrameName: file.name,
            error: ""
          });
        } else {
          patchClipVideoState(recordId, setKey, clipIndex, {
            lastFrameDataUrl: dataUrl,
            lastFrameName: file.name,
            error: ""

function toPrettyJson(input: unknown, maxLength = 0) {
  if (input === null || input === undefined) {
    return "";
  }
  let text = "";
  try {
    text = JSON.stringify(input, null, 2);
  } catch (_error) {
    text = String(input);
  }
  if (maxLength <= 0 || text.length <= maxLength) {
    return text;
  }
  const hiddenLength = text.length - maxLength;
  return `${text.slice(0, maxLength)}\n\n... е®ёеҸүеҹ…йҸӮ?${hiddenLength} ж¶“оҒ„з“§з»—оӣҶ;
}


  pushLine("жҫ¶ж ¬оқҮ", result.appearanceDescription);
  pushLine("жЈ°ж»ҶеЈҠ", result.colorAnalysis);
  pushLine("зҒҸе“„оҮӯ/з‘ҷеӢ¬зүё", result.sizeAndSpecs);
  pushLine("жөЈи·Ёж•ӨйҚҰзғҳж«ҷ/йҗ©оҶҪзҲЈжөңиҷ№е…ў", result.usageAndTargetAudience);
  pushLine("з’ҮпёҪе„ҸйҺ»еҝҡе Ә", result.detailedDescription);
  if (Array.isArray(result.sellingPoints) && result.sellingPoints.length) {
    lines.push(`йҚ—ж «еҒЈ: ${result.sellingPoints.map((item) => safeText(item)).filter(Boolean).join("й”ӣ?)}`);

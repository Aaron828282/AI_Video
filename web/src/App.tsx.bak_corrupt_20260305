const EXPLICIT_API_BASE = String(import.meta.env.VITE_API_BASE ?? "").trim();
const DEFAULT_LOCAL_API_BASE = "http://127.0.0.1:8787";

function normalizeApiBase(input: unknown) {
  return String(input || "").trim().replace(/\/+$/, "");
}

function resolveApiBase() {
  if (EXPLICIT_API_BASE) {
    return normalizeApiBase(EXPLICIT_API_BASE);
  }
  if (typeof window !== "undefined") {
    const origin = normalizeApiBase(window.location.origin);
    if (String(window.location.port || "") === "8787" && origin) {
      return origin;
    }
  }
  return DEFAULT_LOCAL_API_BASE;
}

function buildApiBaseCandidates(primaryBase: string) {
  const candidates: string[] = [];
  const addCandidate = (value: string) => {
    const normalized = normalizeApiBase(value);
    if (normalized && !candidates.includes(normalized)) {
      candidates.push(normalized);
    }
  };
  addCandidate(primaryBase);
  if (!EXPLICIT_API_BASE) {
    if (typeof window !== "undefined" && String(window.location.port || "") === "8787") {
      addCandidate(window.location.origin);
    }
    addCandidate(DEFAULT_LOCAL_API_BASE);
    addCandidate("http://localhost:8787");
  }
  return candidates;
}

const API_BASE = resolveApiBase();
const API_BASE_CANDIDATES = buildApiBaseCandidates(API_BASE);

function buildApiUrl(path: string, base = API_BASE) {
  const normalizedPath = path.startsWith("/") ? path : `/${path}`;
  return `${normalizeApiBase(base)}${normalizedPath}`;
}

async function apiFetch(path: string, init?: RequestInit) {
  const normalizedPath = path.startsWith("/") ? path : `/${path}`;
  let lastError: unknown = null;
  for (const base of API_BASE_CANDIDATES) {
    try {
      return await fetch(buildApiUrl(normalizedPath, base), init);
    } catch (error) {
      lastError = error;
    }
  }
  throw lastError instanceof Error ? lastError : new Error("Failed to fetch");
}
